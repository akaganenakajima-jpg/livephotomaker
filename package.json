{
  "name": "video-to-livephoto",
  "version": "0.1.0",
  "private": true,
  "description": "Convert videos to Live Photos and save to Photos library. Windows + Expo + EAS.",
  "main": "expo-router/entry",
  "engines": {
    "node": ">=20.11.0 <21"
  },
  "scripts": {
    "postinstall": "tsc -p modules/expo-live-photo-exporter/plugin && node scripts/patch-expo-iap.js",
    "build:plugin": "tsc -p modules/expo-live-photo-exporter/plugin",
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "check:marketing": "bash scripts/hooks/check-marketing-copy.sh",
    "check:iap": "bash scripts/hooks/check-iap-identifiers.sh",
    "check:bundle": "bash scripts/hooks/check-bundle-identifier.sh",
    "check:placeholders": "bash scripts/hooks/check-placeholders.sh",
    "check:all": "npm run lint && npm run typecheck && npm run test && npm run check:marketing && npm run check:iap && npm run check:bundle && npm run check:placeholders",
    "preflight": "npm run check:all",
    "eas:login": "eas login",
    "eas:configure": "eas build:configure",
    "eas:build:ios:dev": "eas build --profile development --platform ios",
    "eas:build:ios:preview": "eas build --profile preview --platform ios",
    "eas:build:ios:prod": "eas build --profile production --platform ios",
    "eas:submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "expo": "~51.0.0",
    "expo-av": "~14.0.0",
    "expo-build-properties": "~0.12.5",
    "expo-constants": "~16.0.0",
    "expo-dev-client": "~4.0.29",
    "expo-file-system": "~17.0.0",
    "expo-iap": "^2.6.0",
    "expo-image-picker": "~15.1.0",
    "expo-linking": "~6.3.0",
    "expo-media-library": "~16.0.0",
    "expo-router": "~3.5.0",
    "expo-splash-screen": "~0.27.0",
    "expo-status-bar": "~1.12.0",
    "expo-system-ui": "~3.0.0",
    "expo-video-thumbnails": "~8.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-google-mobile-ads": "^13.2.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.0",
    "zustand": "^4.5.2"
  },
  "overrides": {
    "expo-font": "~12.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.79",
    "@types/react-test-renderer": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "prettier": "^3.2.5",
    "react-test-renderer": "18.2.0",
    "typescript": "~5.3.3"
  }
}
