# Copy this file to `.env` and fill in the values.
# `.env` is gitignored. Never commit real secrets.
#
# Every variable prefixed with `EXPO_PUBLIC_` is inlined into the JS bundle at
# build time, so do NOT put secrets here — only values that are safe to ship.

# --- App identity ---
EXPO_PUBLIC_APP_NAME=Video to Live Photo
EXPO_PUBLIC_ENV=development

# --- Expo / EAS project id ---
# Run `npx eas init` once to create the project. The command prints a UUID
# like `12345678-aaaa-bbbb-cccc-1234567890ab`. Paste it here AND (optionally)
# into `app.config.ts` via the `EXPO_PUBLIC_EAS_PROJECT_ID` env var.
# While this stays empty, `check:placeholders` will fail the build.
EXPO_PUBLIC_EAS_PROJECT_ID=

# --- AdMob (iOS) ---
# Replace with your real ids from the AdMob console before production.
# During development, Google provides safe test ids (see
# https://developers.google.com/admob/ios/test-ads):
#   APP ID        : ca-app-pub-3940256099942544~1458002511
#   REWARDED ID   : ca-app-pub-3940256099942544/1712485313
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511
EXPO_PUBLIC_ADMOB_IOS_REWARDED_UNIT_ID=ca-app-pub-3940256099942544/1712485313
